# wrapped add expression
_ = 1 + 2

# wrapped symbol literal
_ = :ok

# wrapped interpolated string literal
_ = "Hello \(name)!"

# wrapped multi-line string literal
_ = ```
    This text
    will have
    leading whitespace
    removed.
```

# wrapped multi-line string literal with interpolation
_ = ```
    Girls: \(girls.join(", "))
    Boys: \(boys.join(", "))
```

# wrapped multi-line string literal with interpolation spanning lines
_ = ```
    Value: \(
        a +
        b
    )
```

# wrapped multi-line string literal with processor
_ = ```mustache(context)
    Hello, {{name}}
```

# wrapped tuple expression
_ = (a: :x, b: :y)

# wrapped typed array expression
_ = Int[1, 2]

# wrapped fixed-size array expression
_ = [3]Int[1, 2, 3]

# wrapped fixed-size array block initializer
_ = [n]Int { |index| index }

# wrapped fixed-size array block initializer with explicit size
_ = [4]Int { |i| i + 1 }

# wrapped named fixed-size array expression
_ = IPv4Address[1, 2, 3, 4]

# wrapped named fixed-size array block initializer
_ = IPv4Address { |i| i + 1 }

# wrapped namespaced fixed-size array expression
_ = ipv4.Address[1, 2, 3, 4]

# wrapped namespaced fixed-size array block initializer
_ = ipv4.Address { |i| i + 1 }

# wrapped import expression
_ = import("math")

# wrapped typeof expression
_ = typeof(answer)

# wrapped meta expression
_ = $(name: "Brent")

# wrapped type constructor call
_ = Person(name: "Brent")

# wrapped type constructor call with function block
_ = Reader[[]Byte](handle) { |bytes| bytes }

# wrapped type comparison expression
_ = value is (Int | String)

# wrapped range expression
_ = foo.bar..foo.qux

# wrapped unary on member chain
_ = !foo.bar.flag

# wrapped member access chain with indexing
_ = a.b.c[d]

# wrapped ordinal member access
_ = pair.0

# wrapped safe indexed access on member chain
_ = users.list[0]!

# wrapped indexed function call
_ = some_funcs[5](x + 1)

# wrapped tuple update followed by member access
_ = user.(name: "Brent").name

# wrapped block expression
_ = {
    ready = true
    ready
}

# wrapped block expression with return in if
_ = {
    if !ready { return }
    fallback
}

# wrapped if expression
_ = if ready { value } else { fallback }

# wrapped for expression with break in if
_ = for i = 0 {
    if i >= 10 { break i }
    i + 1
}

# wrapped for expression with continue in if
_ = for i = 0; i < 10 {
    if i % 2 == 0 { continue i + 1 }
    i + 1
}

# wrapped for-in expression
_ = for acc = 0; i in items { acc + i }

# wrapped inline for expression
_ = inline for acc = (d: 0, e: ""); name, value in (a: 1, b: "Hello") {
    if name == :a { acc.(d: value + 1) }
    else { acc.(e: value + " World") }
}
