# wrapped add expression
_ = 1 + 2

# wrapped symbol literal
_ = :ok

# wrapped tuple expression
_ = (a: :x, b: :y)

# wrapped typed array expression
_ = Int[1, 2]

# wrapped fixed-size array expression
_ = [3]Int[1, 2, 3]

# wrapped fixed-size array block initializer
_ = [n]Int { |index| index }

# wrapped fixed-size array block initializer with explicit size
_ = [4]Int { |i| i + 1 }

# wrapped named fixed-size array expression
_ = IPv4Address[1, 2, 3, 4]

# wrapped named fixed-size array block initializer
_ = IPv4Address { |i| i + 1 }

# wrapped namespaced fixed-size array expression
_ = Address[1, 2, 3, 4]

# wrapped namespaced fixed-size array block initializer
_ = Address { |i| i + 1 }

# wrapped import expression
_ = import("math")

# wrapped typeof expression
_ = typeof(answer)

# wrapped meta expression
_ = $(name: "Brent")

# wrapped type comparison expression
_ = value is (Int | String)

# wrapped range expression
_ = foo.bar..foo.qux

# wrapped unary on member chain
_ = !foo.bar.flag

# wrapped member access chain with indexing
_ = a.b.c[d]

# wrapped ordinal member access
_ = pair.0

# wrapped safe indexed access on member chain
_ = users.list[0]!

# wrapped indexed function call
_ = some_funcs[5](x + 1)

# wrapped tuple update followed by member access
_ = user.(name: "Brent").name

# wrapped block expression
_ = {
    ready = true
    ready
}

# wrapped if expression
_ = if ready {
    value
} else {
    fallback
}
